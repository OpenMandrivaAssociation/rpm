diff --git a/docs/manual/spec.md b/docs/manual/spec.md
index fc0acd1..bc325f9 100644
--- a/docs/manual/spec.md
+++ b/docs/manual/spec.md
@@ -875,6 +875,55 @@ Example:
     %caps(cap_net_raw=p) %{_bindir}/foo
 ```
 
+### Renaming packaged paths (`as`)
+
+A file may be packaged under a different path than it has in the build root
+by using the `as` keyword between two absolute paths:
+
+```
+	<source path> as <package path>
+```
+
+Content is read from `<source path>` relative to the build root, but the
+file is recorded and installed as `<package path>`. Both paths must be
+absolute and separated from the keyword by whitespace, so that a directory
+component named `as` is not mistaken for the keyword.
+
+This is useful when different subpackages need to own the same install path
+with different content, for example a text-only and a GUI binary both
+installed as `/usr/bin/abc`:
+
+```
+	%install
+	install -D -m755 abc-text %{buildroot}%{_bindir}/abc-text
+	install -D -m755 abc-gui %{buildroot}%{_bindir}/abc-gui
+
+	%files
+	%{_bindir}/abc-text as %{_bindir}/abc
+
+	%files gui
+	%{_bindir}/abc-gui as %{_bindir}/abc
+```
+
+Attributes such as `%attr`, `%config`, `%ghost` and `%dir` apply as usual
+to the packaged path. Recursive directories cannot be renamed with `as`
+(use an explicit `%dir` only for the directory entry itself). Shell
+globbing is not applied to entries that use `as`. The keyword cannot be
+combined with special `%doc` / `%license` forms, `%docdir` or `%pubkey`.
+Duplicate paths within the *same* package still fail; the feature is
+intended for different packages/subpackages owning the same path.
+
+The package path (`DEST`) is normalized like ordinary file entries
+(redundant `/` and `.` / `..` segments are collapsed). Unpackaged-file
+checks still account for the on-disk source path in the build root, not
+`DEST`, so a leftover file at the destination path can still be reported
+as unpackaged.
+
+When automatic debuginfo generation is enabled, `.debug` files produced
+by `find-debuginfo` from the on-disk `SOURCE` path are packaged under
+the corresponding path for `DEST` (so the debuginfo member matches the
+installed ELF name).
+
 ### Shell Globbing
 
 The usual rules for shell globbing apply (see `glob(7)`), including brace
diff --git a/tests/rpmbuild.at b/tests/rpmbuild.at
index 935b18d..288dfdf 100644
--- a/tests/rpmbuild.at
+++ b/tests/rpmbuild.at
@@ -4212,3 +4212,119 @@ runroot rpmbuild -bb --quiet --target x86_64 --with hello32 \
     /usr/local/bin/hello (ELF 32-bit)
 ])
 RPMTEST_CLEANUP
+
+# ------------------------------
+# Package a file under an alternate path with "as"
+RPMTEST_SETUP_RW([rpmbuild file as rename])
+AT_KEYWORDS([build] [files])
+RPMTEST_CHECK([
+runroot rpmbuild -bb --quiet /data/SPECS/fileas.spec
+],
+[0],
+[],
+[])
+
+# Both packages own /usr/bin/abc but with different content/digests
+RPMTEST_CHECK([
+runroot rpm -qp --qf "[%{filenames}\n]" /build/RPMS/noarch/fileas-1.0-1.noarch.rpm
+runroot rpm -qp --qf "[%{filenames}\n]" /build/RPMS/noarch/fileas-gui-1.0-1.noarch.rpm
+],
+[0],
+[/usr/bin/abc
+/usr/share/as/data
+/usr/bin/abc
+],
+[])
+
+RPMTEST_CHECK([
+runroot sh -c 'rpm2cpio /build/RPMS/noarch/fileas-1.0-1.noarch.rpm | cpio -i --to-stdout ./usr/bin/abc'
+echo
+runroot sh -c 'rpm2cpio /build/RPMS/noarch/fileas-gui-1.0-1.noarch.rpm | cpio -i --to-stdout ./usr/bin/abc'
+echo
+],
+[0],
+[text-variant
+gui-variant
+],
+[ignore])
+RPMTEST_CLEANUP
+
+# Negative cases for SOURCE as DEST
+RPMTEST_SETUP_RW([rpmbuild file as rename errors])
+AT_KEYWORDS([build] [files])
+
+# Same-package duplicate DEST fails when terminate_build is set
+RPMTEST_CHECK([
+runroot rpmbuild -bb --quiet \
+  --define '_duplicate_files_terminate_build 1' \
+  --define 'case 1' /data/SPECS/fileas-bad.spec
+],
+[1],
+[],
+[error: File listed twice: /usr/bin/x
+])
+
+# Missing package path after as
+RPMTEST_CHECK([
+runroot rpmbuild -bb --quiet --define 'case 2' /data/SPECS/fileas-bad.spec
+],
+[1],
+[],
+[error: Missing package path after "as"
+])
+
+# Recursive directory without %dir
+RPMTEST_CHECK([
+runroot rpmbuild -bb --quiet --define 'case 3' /data/SPECS/fileas-bad.spec
+],
+[1],
+[],
+[error: Cannot use "as" with recursive directories: /build/BUILD/fileas-bad-1.0-build/BUILDROOT/usr/lib/dirsrc
+])
+
+# Special %doc form cannot use as
+RPMTEST_CHECK([
+runroot rpmbuild -bb --quiet --define 'case 4' /data/SPECS/fileas-bad.spec
+],
+[1],
+[],
+[error: Cannot use "as" with special file forms: readme
+])
+RPMTEST_CLEANUP
+
+# ------------------------------
+# Renamed binaries get debuginfo under the packaged (DEST) path
+RPMTEST_SETUP_RW([rpmbuild file as rename debuginfo])
+AT_KEYWORDS([build] [files] [debuginfo])
+RPMTEST_SKIP_IF([$DEBUGINFO_DISABLED])
+RPMTEST_CHECK([
+export CFLAGS="-g"
+# Subpackages mode rewrites debuginfo from the main package file list,
+# which is where SOURCE as DEST renames are applied.
+rundebug rpmbuild -bb --quiet \
+  --define '_debuginfo_subpackages 1' \
+  /data/SPECS/fileas-debug.spec
+],
+[0],
+[],
+[ignore])
+
+RPMTEST_CHECK([
+runroot rpm -qp --qf "[%{filenames}\n]" /build/RPMS/*/fileasdbg-1.0-1.*.rpm
+],
+[0],
+[/usr/bin/hello-packaged
+],
+[])
+
+# Packaged debug member uses DEST; SOURCE name must not appear as a member path
+RPMTEST_CHECK([
+runroot sh -c 'rpm2cpio /build/RPMS/*/fileasdbg-debuginfo-1.0-1.*.rpm | cpio -t' | \
+  grep -q 'hello-packaged'
+runroot sh -c 'rpm2cpio /build/RPMS/*/fileasdbg-debuginfo-1.0-1.*.rpm | cpio -t' | \
+  grep -q 'hello-on-disk'; test $? -eq 1
+],
+[0],
+[ignore],
+[ignore])
+RPMTEST_CLEANUP
