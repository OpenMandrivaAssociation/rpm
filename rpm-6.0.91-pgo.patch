diff --git a/tests/rpmpgo.at b/tests/rpmpgo.at
new file mode 100644
index 0000000..f87c376
--- /dev/null
+++ b/tests/rpmpgo.at
@@ -0,0 +1,272 @@
+#    rpmpgo.at: test %pgo (Profile-Guided Optimization) support
+#
+#    This program is free software; you can redistribute it and/or modify
+#    it under the terms of the GNU General Public License as published by
+#    the Free Software Foundation; either version 2 of the License, or
+#    (at your option) any later version.
+
+AT_BANNER([RPM PGO (Profile-Guided Optimization)])
+
+# ------------------------------
+# Build without %pgo section - verify normal build is unaffected
+RPMTEST_SETUP_RW([rpmbuild without %pgo section])
+AT_KEYWORDS([build pgo])
+RPMTEST_CHECK([
+
+rpmbuild \
+  --define "debug_package %{nil}" \
+  -bb ${RPMDATA}/SPECS/pgohello-nopgo.spec
+],
+[0],
+[ignore],
+[ignore])
+
+# Verify the package was created and contains the binary
+RPMTEST_CHECK([
+runroot rpm -qp --qf "%{name}-%{version}\n" /build/RPMS/*/pgohello-1.0-1.*.rpm
+],
+[0],
+[pgohello-1.0
+],
+[])
+
+RPMTEST_CLEANUP
+
+# ------------------------------
+# Build with %pgo section using GCC - verify PGO is enabled
+RPMTEST_SETUP_RW([rpmbuild with %pgo section (GCC)])
+AT_KEYWORDS([build pgo])
+RPMTEST_CHECK([
+
+rpmbuild \
+  --define "debug_package %{nil}" \
+  --define "__cc gcc" \
+  -bb ${RPMDATA}/SPECS/pgohello.spec 2>&1 | \
+  grep -qF "PGO: profile-guided optimization enabled"
+],
+[0],
+[],
+[])
+
+# Verify the PGO build produced a package
+RPMTEST_CHECK([
+runroot rpm -qp --qf "%{name}-%{version}\n" /build/RPMS/*/pgohello-1.0-1.*.rpm
+],
+[0],
+[pgohello-1.0
+],
+[])
+
+RPMTEST_CLEANUP
+
+# ------------------------------
+# Build with %pgo section using Clang - verify PGO is enabled
+RPMTEST_SETUP_RW([rpmbuild with %pgo section (Clang)])
+AT_KEYWORDS([build pgo])
+RPMTEST_SKIP_IF([! which clang >/dev/null 2>&1])
+RPMTEST_CHECK([
+
+rpmbuild \
+  --define "debug_package %{nil}" \
+  --define "__cc clang" \
+  -bb ${RPMDATA}/SPECS/pgohello.spec 2>&1 | \
+  grep -qF "PGO: profile-guided optimization enabled"
+],
+[0],
+[],
+[])
+
+# Verify the PGO build produced a package
+RPMTEST_CHECK([
+runroot rpm -qp --qf "%{name}-%{version}\n" /build/RPMS/*/pgohello-1.0-1.*.rpm
+],
+[0],
+[pgohello-1.0
+],
+[])
+
+RPMTEST_CLEANUP
+
+# ------------------------------
+# Verify GCC PGO build runs both pass 1 and pass 2
+RPMTEST_SETUP_RW([rpmbuild PGO two-pass build (GCC)])
+AT_KEYWORDS([build pgo])
+RPMTEST_CHECK([
+
+rpmbuild \
+  --define "debug_package %{nil}" \
+  --define "__cc gcc" \
+  -bb ${RPMDATA}/SPECS/pgohello.spec 2>&1 | \
+  grep -F "PGO:" | \
+  grep -cF "pass"
+],
+[0],
+[2
+],
+[])
+
+RPMTEST_CLEANUP
+
+# ------------------------------
+# Verify GCC PGO injects -fprofile-generate in pass 1 and -fprofile-use in pass 2
+RPMTEST_SETUP_RW([rpmbuild PGO flag injection (GCC)])
+AT_KEYWORDS([build pgo])
+RPMTEST_CHECK([
+
+rpmbuild \
+  --define "debug_package %{nil}" \
+  --define "__cc gcc" \
+  -bb ${RPMDATA}/SPECS/pgohello.spec 2>&1 | \
+  grep -oF -- "-fprofile-generate" | head -1
+],
+[0],
+[-fprofile-generate
+],
+[])
+
+RPMTEST_CHECK([
+
+rpmbuild \
+  --define "debug_package %{nil}" \
+  --define "__cc gcc" \
+  -bb ${RPMDATA}/SPECS/pgohello.spec 2>&1 | \
+  grep -oF -- "-fprofile-use" | head -1
+],
+[0],
+[-fprofile-use
+],
+[])
+
+RPMTEST_CLEANUP
+
+# ------------------------------
+# Verify Clang PGO injects -fprofile-generate and -fprofile-use
+RPMTEST_SETUP_RW([rpmbuild PGO flag injection (Clang)])
+AT_KEYWORDS([build pgo])
+RPMTEST_SKIP_IF([! which clang >/dev/null 2>&1])
+RPMTEST_CHECK([
+
+rpmbuild \
+  --define "debug_package %{nil}" \
+  --define "__cc clang" \
+  -bb ${RPMDATA}/SPECS/pgohello.spec 2>&1 | \
+  grep -oF -- "-fprofile-generate" | head -1
+],
+[0],
+[-fprofile-generate
+],
+[])
+
+RPMTEST_CHECK([
+
+rpmbuild \
+  --define "debug_package %{nil}" \
+  --define "__cc clang" \
+  -bb ${RPMDATA}/SPECS/pgohello.spec 2>&1 | \
+  grep -oF -- "-fprofile-use" | head -1
+],
+[0],
+[-fprofile-use
+],
+[])
+
+RPMTEST_CLEANUP
+
+# ------------------------------
+# Verify noarch package skips %pgo even when present
+RPMTEST_SETUP_RW([rpmbuild %pgo skipped for noarch])
+AT_KEYWORDS([build pgo])
+RPMTEST_CHECK([
+
+rpmbuild \
+  --define "debug_package %{nil}" \
+  -bb ${RPMDATA}/SPECS/pgohello-noarch.spec 2>&1 | \
+  grep -cF "PGO: profile-guided optimization enabled" || true
+],
+[0],
+[0
+],
+[])
+
+# Package should still be built successfully (the %pgo exit 1 was never run)
+RPMTEST_CHECK([
+runroot rpm -qp --qf "%{name}-%{version}\n" /build/RPMS/noarch/pgohello-noarch-1.0-1.noarch.rpm
+],
+[0],
+[pgohello-noarch-1.0
+],
+[])
+
+RPMTEST_CLEANUP
+
+# ------------------------------
+# Verify PGO runs the training workload
+RPMTEST_SETUP_RW([rpmbuild PGO training workload runs])
+AT_KEYWORDS([build pgo])
+RPMTEST_CHECK([
+
+rpmbuild \
+  --define "debug_package %{nil}" \
+  --define "__cc gcc" \
+  -bb ${RPMDATA}/SPECS/pgohello.spec 2>&1 | \
+  grep -qF "PGO: running training workload"
+],
+[0],
+[],
+[])
+
+RPMTEST_CLEANUP
+
+# ------------------------------
+# Verify PGO wipes build directory between passes
+RPMTEST_SETUP_RW([rpmbuild PGO wipes build directory])
+AT_KEYWORDS([build pgo])
+RPMTEST_CHECK([
+
+rpmbuild \
+  --define "debug_package %{nil}" \
+  --define "__cc gcc" \
+  -bb ${RPMDATA}/SPECS/pgohello.spec 2>&1 | \
+  grep -qF "PGO: wiping build directory"
+],
+[0],
+[],
+[])
+
+RPMTEST_CLEANUP
+
+# ------------------------------
+# Verify %pgo section is parsed correctly alongside BuildSystem (declarative build)
+RPMTEST_SETUP_RW([rpmspec %pgo with BuildSystem])
+AT_KEYWORDS([build pgo buildsystem])
+
+cp "${RPMTEST}/data/macros.buildsystem" "${RPMTEST}/${RPM_CONFIGDIR_PATH}/macros.d/"
+
+RPMTEST_CHECK([
+cat > bspgo.spec << 'SPECEOF'
+Name: bspgotest
+Version: 1.0
+Release: 1
+Source: amhello-1.0.tar.gz
+License: GPLv2
+Summary: BuildSystem + PGO test
+BuildSystem: autotools
+
+%description
+Test that BuildSystem and %%pgo coexist.
+
+%pgo
+echo "Running PGO training"
+
+%files
+%{_bindir}/hello
+SPECEOF
+
+runroot rpmspec -P bspgo.spec 2>&1 | grep -cE '^%(prep|conf|build|install|pgo)$'
+],
+[0],
+[5
+],
+[])
+
+RPMTEST_CLEANUP
