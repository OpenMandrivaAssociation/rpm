+/*
+ * Section detection runs on the macro-expanded line, where %% has already
+ * become a single %.  A line that began with %% in the source is an escaped
+ * literal percent (e.g. %%package inside %install for a .specpart), not a
+ * section boundary — even though the expanded text looks like one.
+ */
+static int isPartLine(rpmSpec spec)
+{
+    if (spec->lineEscapedPercent)
+	return PART_NONE;
+    return isPart(spec->line);
+}
