 # optionally removing parameters declared in brackets. Also, we drop any macros
 # that start with __ as these are considered internal/private and should not be
 # exposed as a public API.
+#
+# Buildsystem section suffixes (longest first so generate_buildrequires wins
+# over buildrequires over build):
+#   generate_buildrequires, buildrequires, install, build, check, clean,
+#   conf, prep
+
+# Extract the buildsystem name from a macro, or empty if not a section macro.
+buildsystem_name()
+{
+    local macro=$1 name=
+    case $macro in
+    buildsystem_*_generate_buildrequires)
+	name=${macro#buildsystem_}
+	name=${name%_generate_buildrequires}
+	;;
+    buildsystem_*_buildrequires)
+	name=${macro#buildsystem_}
+	name=${name%_buildrequires}
+	;;
+    buildsystem_*_install)
+	name=${macro#buildsystem_}
+	name=${name%_install}
+	;;
+    buildsystem_*_build)
+	name=${macro#buildsystem_}
+	name=${name%_build}
+	;;
+    buildsystem_*_check)
+	name=${macro#buildsystem_}
+	name=${name%_check}
+	;;
+    buildsystem_*_clean)
+	name=${macro#buildsystem_}
+	name=${name%_clean}
+	;;
+    buildsystem_*_conf)
+	name=${macro#buildsystem_}
+	name=${name%_conf}
+	;;
+    buildsystem_*_prep)
+	name=${macro#buildsystem_}
+	name=${name%_prep}
+	;;
+    esac
+    # "default" is the global fallback shipped with rpm, not a real provider
+    if [ -n "$name" ] && [ "$name" != default ]; then
+	printf '%s\n' "$name"
+    fi
+    return 0
+}
 
 while read filename
 do
+    bsprov=
     for macro in $(rpm --macros="${filename}" -E "%dump" 2>&1 | grep '^-13:' | awk '{print $2}' | sed -e 's|(.*)||' -e '/^__/d'); do
-        echo "rpm_macro(${macro})"
+	echo "rpm_macro(${macro})"
+	name=$(buildsystem_name "$macro")
+	if [ -n "$name" ]; then
+	    case " $bsprov " in
+	    *" $name "*) ;;
+	    *) bsprov="${bsprov} ${name}" ;;
+	    esac
+	fi
+    done
+    for name in $bsprov; do
+	echo "rpm-build(${name})"
     done
 done
