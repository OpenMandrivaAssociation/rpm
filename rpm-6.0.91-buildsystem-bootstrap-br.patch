+/*
+ * Arrange BuildRequires for a BuildSystem:
+ *  - always require rpm-build(name), the virtual provide for the macros
+ *  - if %buildsystem_name_buildrequires is defined, expand and parse it
+ *    as additional static BuildRequires (tools, versioned deps, etc.)
+ */
+static rpmRC addBuildsystemRequires(rpmSpec spec, const char *name)
+{
+    rpmRC rc = RPMRC_FAIL;
+    char *autobr = NULL;
+    char *mn = NULL;
+    char *brs = NULL;
+
+    if (spec->sourcePackage == NULL)
+	goto exit;
+
+    rasprintf(&autobr, "rpm-build(%s)", name);
+    if (parseRCPOT(spec, spec->sourcePackage, autobr, RPMTAG_BUILDREQUIRES,
+		   0, 0, addReqProvPkg, NULL))
+	goto exit;
+
+    mn = rstrscat(NULL, "buildsystem_", name, "_buildrequires", NULL);
+    if (rpmMacroIsParametric(NULL, mn))
+	brs = rpmExpand("%", mn, NULL);
+    else if (rpmMacroIsDefined(NULL, mn))
+	brs = rpmExpand("%{", mn, "}", NULL);
+
+    if (brs) {
+	char *p = brs;
+	SKIPSPACE(p);
+	if (*p && parseRCPOT(spec, spec->sourcePackage, p, RPMTAG_BUILDREQUIRES,
+			     0, 0, addReqProvPkg, NULL))
+	    goto exit;
+    }
+
+    rc = RPMRC_OK;
+exit:
+    free(autobr);
+    free(mn);
+    free(brs);
+    return rc;
+}
