+/*
+ * Ensure BuildSystem macros are usable for a real build. Soft-missing at
+ * parse time is fine (bootstrap via rpm-build(name) BR); once we are about
+ * to run build sections, missing macros with unfilled required sections
+ * is a hard error. Call after static BR check so the BR message wins when
+ * the provider package is simply not installed yet.
+ */
+int validateBuildsystem(rpmSpec spec)
+{
+    char *buildsystem = rpmExpand("%{?buildsystem}", NULL);
+    int rc = 0;
+    int st = 0;
+    int need = 0;
+
+    if (*buildsystem == '\0')
+	goto exit;
+
+    st = checkBuildsystem(spec, buildsystem);
+    if (st == 0)
+	goto exit;
+
+    /* Manual overrides of required sections make the macros optional */
+    for (struct sectname_s *sc = sectList; sc->name; sc++) {
+	if (sc->required && spec->sections[sc->section] == NULL) {
+	    need = 1;
+	    break;
+	}
+    }
+    if (!need)
+	goto exit;
+
+    if (st > 0) {
+	rpmlog(RPMLOG_ERR,
+	       _("BuildSystem macros for '%s' are not available "
+		 "(BuildRequires: rpm-build(%s)?)\n"),
+	       buildsystem, buildsystem);
+    }
+    /* st < 0 already reported by checkBuildsystem */
+    rc = -1;
+
+exit:
+    free(buildsystem);
+    return rc;
+}
